# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_secure_password

# Domain
DOMAIN=stroycompany.ru

# Frontend
NUXT_PUBLIC_API_URL=http://backend:8080

# Backend
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Data Source=/app/data/database.db
UploadPath=/app/uploads

# SSL (optional for local dev)
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
